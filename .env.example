# CloudCLI UI Environment Configuration
# Only includes variables that are actually used in the code
#
# TIP: Run 'cloudcli status' to see where this file should be located
#      and to view your current configuration.
#
# Available CLI commands:
#   claude-code-ui    - Start the server (default)
#   cloudcli start    - Start the server
#   cloudcli status   - Show configuration and data locations
#   cloudcli help     - Show help information
#   cloudcli version  - Show version information

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (Express API + WebSocket server)
# 若 EADDRINUSE：先结束占用该端口的旧 node 进程，或改用其它端口（如 3002）
# If you see EADDRINUSE, stop the other process or set SERVER_PORT to a free port.
#API server
SERVER_PORT=3001
#Frontend port
VITE_PORT=5173

# Host/IP to bind servers to (default: 0.0.0.0 for all interfaces)
# Use 127.0.0.1 to restrict to localhost only
HOST=0.0.0.0

# Uncomment the following line if you have a custom claude cli path other than the default "claude"
# CLAUDE_CLI_PATH=claude

# ---------- Local claudecode (OpenAI-compat fork, e.g. /apps/claude-code) ----------
# Prefer claudecode over `claude` for web terminal + Agent SDK when unset: set CLAUDE_CODE_USE_OPENAI_COMPAT_API=1
# CLOUDCLI_CLAUDE_CLI_PRIORITY=claudecode   # or: claude
# Absolute path to bin (SDK spawn). Default tries /apps/claude-code/bin/claudecode then PATH.
# CLAUDE_CODE_EXECUTABLE=/apps/claude-code/bin/claudecode
# CLAUDE_CODE_ROOT=/apps/claude-code
# When the SDK executable is `claudecode`, CloudCLI loads the model picker from `claudecode --list-models`
# (secrets stay on the server; only parsed id/label pairs are sent to the browser).
# OpenAI-compat chat (see your fork’s .env.example):
# CLAUDE_CODE_USE_OPENAI_COMPAT_API=1
# ANTHROPIC_BASE_URL=https://your-gateway.example/v1
# ANTHROPIC_API_KEY=sk-...
# ANTHROPIC_AUTH_TOKEN=...   # alternative to API key (Bearer)
# Default model id for gateway + UI when preset (sonnet/opus/…) is not valid:
# ANTHROPIC_MODEL=gpt-4o
# ANTHROPIC_DEFAULT_SONNET_MODEL=...

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# =============================================================================
# SSH 远程服务器 + Vault（侧栏「服务器」标签）
# SSH remote servers (P0) — Vault encrypts private keys / passwords at rest in the DB
# =============================================================================
# 未设置时：界面会提示设置 CLOUDCLI_VAULT_KEY；拉取服务器列表等接口可能返回非 JSON（例如反向代理的 HTML），表现为「not valid JSON」。
# If unset: the UI shows a warning; server APIs that touch the vault may fail and return HTML, causing JSON parse errors in the browser.
#
# CLOUDCLI_VAULT_KEY — 必须能解码为 32 字节，用于 AES-256-GCM。推荐其一：
#   • base64 编码的 32 随机字节（decode 后长度=32，字符串通常约 44 字符，可含尾部的 =）
#   • 或 64 个十六进制字符（256 bit）
# Must decode to 32 bytes for AES-256-GCM. Either:
#   • base64(32 random bytes) — string is often ~44 chars; or
#   • 64 hex characters.
#
# 生成示例 / Generate a new key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   openssl rand -base64 32
#
# 将上面命令的输出（单行）作为变量值。设置或修改后必须重启后端。不要把真实密钥提交到版本库，只放在本机 .env。
# Paste the one-line output as the value. Restart the backend after set or change. Do not commit real keys.
#
# CLOUDCLI_VAULT_KEY=

# P2+ 纯 SSH：keepalive 间隔（毫秒，默认 30000）；远端 claude -p 流式输出软上限（字节，默认 20MB）
# CLOUDCLI_SSH_KEEPALIVE_MS=30000
# CLOUDCLI_REMOTE_CLAUDE_MAX_OUTPUT=20971520

# P3：每 (userId, serverId) 主连接复用与限流
# 主连接无引用时空闲回收（毫秒，默认 120000）
# CLOUDCLI_SSH_IDLE_MS=120000
# 同时 exec 通道 / SFTP 子会话上限（默认 8 / 4）
# CLOUDCLI_SSH_MAX_CONCURRENT_EXEC=8
# CLOUDCLI_SSH_MAX_CONCURRENT_SFTP=4
# 远程 bash -lc 单条 exec 超时（毫秒，默认 20000，只关流不拆主连）
# CLOUDCLI_SSH_EXEC_TIMEOUT_MS=20000

# 侧栏「服务器」：远端 claudecode / claude 探测与在线安装（§5.4）
# 基址应指向 **main 树**（如 `.../wyt990/.../haha/main`），勿以 `/install` 结尾；程序会再拼 `install/install.sh`。
# 可改为内网镜像的 https 基址。主机须在白名单内。
# CLOUDCLI_REMOTE_INSTALL_BASE_URL=https://raw.githubusercontent.com/wyt990/claude-code-haha/main
# 逗号分隔的允许主机名（与上面 URL 的 host 须一致，否则拒绝构建安装命令或拒绝用户粘贴的整行命令）
# CLOUDCLI_REMOTE_INSTALL_HOST_ALLOW=raw.githubusercontent.com
# 探测超时（默认 25000ms）、整段安装（curl|bash / irm|iex）超时（默认 600000ms）
# CLOUDCLI_SSH_CLAUDE_PROBE_TIMEOUT_MS=25000
# CLOUDCLI_SSH_INSTALL_TIMEOUT_MS=600000
# 远程 claudecode/claude 探测的详细 [remote-claude-probe] 与 [ssh-servers] claude-probe 终端日志，设为 0 可关闭
# CLOUDCLI_SSH_CLAUDE_PROBE_LOG=0
# 侧栏「打开项目（远程）」在 SSH 上执行 cd + claudecode/-p 的单次超时（默认 120000ms）；默认 -p 文案为 test
# CLOUDCLI_REMOTE_OPEN_PROJECT_TIMEOUT_MS=120000
# CLOUDCLI_REMOTE_OPEN_PROJECT_PROMPT=test

# Path to the authentication database file
# This is where user credentials, API keys, and tokens are stored.
#
# To use a custom location:
# DATABASE_PATH=/path/to/your/custom/auth.db
#
# Claude Code context window size (maximum tokens per session)
VITE_CONTEXT_WINDOW=160000
CONTEXT_WINDOW=160000


